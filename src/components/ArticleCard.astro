---
import OptimizedImage from "./OptimizedImage.astro";
import { tagSlug } from "../lib/taxonomy";

interface Props {
  slug: string;
  title: string;
  category: string;
  type?: string;
  author?: string;
  tags?: string[];
  excerpt: string;
  readTime: string;
  image: string;
}

const {
  slug,
  title,
  category,
  type = "Panduan",
  author = "Redaksi PramukaUpdate",
  tags = [],
  excerpt,
  readTime,
  image,
} = Astro.props;
const visibleTags = tags.slice(0, 2);
const rubricHref = `/rubrik/${category.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "")}`;
---

<article class="card article-card">
  <OptimizedImage src={image} alt="" width={900} height={600} />
  <div class="card-body">
    <div class="article-label-row">
      <a class="eyebrow category-badge" href={rubricHref} data-category={category.toLowerCase()}>{category}</a>
      <span class="article-type">{type}</span>
    </div>
    <h3><a href={`/artikel/${slug}`}>{title}</a></h3>
    <p>{excerpt}</p>
    {visibleTags.length > 0 && (
      <div class="tag-list tag-list-small" aria-label="Tag artikel">
        {visibleTags.map((tag) => (
          <a href={`/tag/${tagSlug(tag)}`}>#{tag}</a>
        ))}
      </div>
    )}
    <small>{author} • {readTime}</small>
  </div>
</article>
