---
import OptimizedImage from "./OptimizedImage.astro";

interface Props {
  slug: string;
  title: string;
  category: string;
  type?: string;
  author?: string;
  excerpt: string;
  readTime: string;
  image: string;
}

const { slug, title, category, type = "Panduan", author = "Redaksi PramukaUpdate", excerpt, readTime, image } = Astro.props;
---

<article class="card article-card">
  <OptimizedImage src={image} alt="" width={900} height={600} />
  <div class="card-body">
    <div class="article-label-row">
      <span class="eyebrow category-badge">{type}</span>
      <a class="rubric-link" href={`/rubrik/${category.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "")}`}>{category}</a>
    </div>
    <h3><a href={`/artikel/${slug}`}>{title}</a></h3>
    <p>{excerpt}</p>
    <small>{author} • {readTime}</small>
  </div>
</article>
