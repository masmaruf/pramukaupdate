---
interface Props {
  contentType?: "website" | "article" | "product" | "page";
  contentId?: string;
  contentTitle?: string;
  category?: string;
  author?: string;
  publishedAt?: string;
}

const {
  contentType = "page",
  contentId = Astro.url.pathname,
  contentTitle = "",
  category = "",
  author = "",
  publishedAt = "",
} = Astro.props;

const endpoint = import.meta.env.PUBLIC_ANALYTICS_ENDPOINT ?? "";
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN ?? "";
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";
const fbPixelId = import.meta.env.PUBLIC_FACEBOOK_PIXEL_ID ?? "551130505241561";
---

{plausibleDomain && (
  <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js"></script>
)}

{gaMeasurementId && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
    <script define:vars={{ gaMeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag("js", new Date());
      gtag("config", gaMeasurementId, {
        page_path: window.location.pathname,
        page_title: document.title,
      });
    </script>
  </>
)}

{fbPixelId && (
  <>
    <script define:vars={{ fbPixelId }}>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', fbPixelId);
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
           src={`https://www.facebook.com/tr?id=${fbPixelId}&ev=PageView&noscript=1`} />
    </noscript>
  </>
)}

<script
  define:vars={{
    endpoint,
    contentType,
    contentId,
    contentTitle,
    category,
    author,
    publishedAt,
    fbPixelId,
  }}
>
  const getTrafficSource = () => {
    const params = new URLSearchParams(window.location.search);
    const utmSource = params.get("utm_source");
    const utmMedium = params.get("utm_medium");
    const utmCampaign = params.get("utm_campaign");

    if (utmSource || utmMedium || utmCampaign) {
      return {
        source: utmSource || "utm",
        medium: utmMedium || "unknown",
        campaign: utmCampaign || "",
        referrer: document.referrer,
      };
    }

    if (!document.referrer) {
      return { source: "direct", medium: "none", campaign: "", referrer: "" };
    }

    const referrerUrl = new URL(document.referrer);
    if (referrerUrl.hostname === window.location.hostname) {
      return { source: "internal", medium: "site", campaign: "", referrer: document.referrer };
    }

    return {
      source: referrerUrl.hostname.replace(/^www\./, ""),
      medium: "referral",
      campaign: "",
      referrer: document.referrer,
    };
  };

  const baseProperties = () => ({
    content_type: contentType,
    content_id: contentId,
    content_title: contentTitle,
    category,
    author,
    published_at: publishedAt,
    path: window.location.pathname,
    ...getTrafficSource(),
  });

  const sendToEndpoint = (name, properties) => {
    if (!endpoint) return;
    const payload = JSON.stringify({
      name,
      properties,
      href: window.location.href,
      sent_at: new Date().toISOString(),
    });

    if (navigator.sendBeacon) {
      navigator.sendBeacon(endpoint, new Blob([payload], { type: "application/json" }));
      return;
    }

    fetch(endpoint, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: payload,
      keepalive: true,
    }).catch(() => {});
  };

  const mapFbEventName = (name) => {
    switch (name) {
      case "content_view":
        return "PageView";
      case "product_detail_click":
        return "ViewContent";
      case "product_payment_click":
        return "InitiateCheckout";
      default:
        return name;
    }
  };

  const sendToFacebookCapi = (fbEventName, eventID, properties) => {
    fetch("/api/facebook-capi", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        eventName: fbEventName,
        eventId: eventID,
        eventSourceUrl: window.location.href,
        clientUserAgent: navigator.userAgent,
        customData: {
          content_name: properties.content_title || properties.product || document.title,
          content_category: properties.category || "",
          content_ids: properties.content_id || properties.product ? [properties.content_id || properties.product] : [],
          content_type: properties.content_type || "product",
          value: properties.value ? parseFloat(properties.value) : undefined,
          currency: properties.currency || "IDR",
        },
      }),
    }).catch(() => {});
  };

  window.pramukaAnalyticsTrack = (name, properties = {}) => {
    const payload = { ...baseProperties(), ...properties };
    const eventRecord = {
      name,
      properties: payload,
      href: window.location.href,
      sent_at: new Date().toISOString(),
    };

    try {
      const key = "pramukaupdate:analytics";
      const current = JSON.parse(window.localStorage.getItem(key) || "[]");
      current.push(eventRecord);
      window.localStorage.setItem(key, JSON.stringify(current.slice(-250)));
    } catch {
      // Local preview storage is optional; ignore browser privacy restrictions.
    }

    if (typeof window.va === "function") {
      window.va("event", { name, data: payload });
    }

    if (typeof window.plausible === "function") {
      window.plausible(name, { props: payload });
    }

    if (typeof window.gtag === "function") {
      window.gtag("event", name, payload);
    }

    sendToEndpoint(name, payload);

    if (fbPixelId) {
      const fbEventName = mapFbEventName(name);
      const eventID = `evt-${Date.now()}-${Math.random().toString(36).substring(2, 9)}`;

      if (typeof window.fbq === "function") {
        window.fbq("track", fbEventName, {
          content_name: payload.content_title || payload.product || document.title,
          content_category: payload.category || "",
          content_ids: payload.content_id || payload.product ? [payload.content_id || payload.product] : [],
          content_type: payload.content_type || "product",
          value: payload.value ? parseFloat(payload.value) : undefined,
          currency: payload.currency || "IDR",
        }, { eventID });
      }

      sendToFacebookCapi(fbEventName, eventID, payload);
    }
  };

  window.pramukaAnalyticsTrack("content_view");

  document.addEventListener("click", (event) => {
    const target = event.target instanceof Element
      ? event.target.closest("[data-analytics-event]")
      : null;

    if (!target) return;

    const properties = {};
    for (const [key, value] of Object.entries(target.dataset)) {
      if (key === "analyticsEvent") continue;
      properties[key.replace(/^analytics/, "").replace(/^[A-Z]/, (char) => char.toLowerCase())] = value;
    }

    window.pramukaAnalyticsTrack(target.dataset.analyticsEvent, properties);
  });
</script>
