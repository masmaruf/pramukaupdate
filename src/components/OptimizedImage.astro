---
import { Image } from "astro:assets";

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  width = 1200,
  height = 800,
  class: className,
  loading = "lazy",
  fetchpriority = "auto",
} = Astro.props;

const isRemoteImage = src.startsWith("http://") || src.startsWith("https://");
---

{
  isRemoteImage ? (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
      format="webp"
      quality={82}
    />
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
    />
  )
}
