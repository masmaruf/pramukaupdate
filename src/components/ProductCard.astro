---
import OptimizedImage from "./OptimizedImage.astro";

interface Props {
  id?: string;
  title: string;
  price: string;
  description: string;
  image?: string;
  badge?: string;
  ctaLabel?: string;
  whatsappUrl?: string;
  bestFor?: string;
}

const {
  id,
  title,
  price,
  description,
  image,
  badge,
  ctaLabel = "Beli via WhatsApp",
  whatsappUrl = "#",
  bestFor,
} = Astro.props;
---

<article class="card product-card">
  <a class="product-media" href={id ? `/produk#${id}` : "/produk"} aria-label={`Lihat detail ${title}`}>
    {image ? <OptimizedImage src={image} alt="" width={900} height={630} /> : <span>↗</span>}
  </a>
  <div class="card-body">
    {badge && <span class="pill">{badge}</span>}
    <h3>{title}</h3>
    <p>{description}</p>
    {bestFor && <small>{bestFor}</small>}
    <div class="product-meta">
      <strong>{price}</strong>
      <a href={whatsappUrl}>{ctaLabel}</a>
    </div>
  </div>
</article>
