---
import OptimizedImage from "./OptimizedImage.astro";

interface Props {
  id?: string;
  title: string;
  category?: string;
  price: string;
  description: string;
  image?: string;
  badge?: string;
  ctaLabel?: string;
  paymentLabel?: string;
  paymentUrl?: string;
  whatsappUrl?: string;
  bestFor?: string;
}

const {
  id,
  title,
  category = "Produk",
  price,
  description,
  image,
  badge,
  ctaLabel = "Beli via WhatsApp",
  paymentLabel = "Bayar via Formulir.com",
  paymentUrl,
  whatsappUrl = "#",
  bestFor,
} = Astro.props;
---

<article class="card product-card">
  <a class="product-media" href={id ? `/produk/${id}` : "/produk"} aria-label={`Lihat detail ${title}`}>
    {image ? <OptimizedImage src={image} alt="" width={900} height={630} /> : <span>↗</span>}
    {badge && <span class="product-badge">{badge}</span>}
  </a>
  <div class="product-card-body">
    <a class="product-title" href={id ? `/produk/${id}` : "/produk"}>{title}</a>
    <p>{description}</p>
    <div class="product-meta">
      <strong>{price}</strong>
      <span>{category} • Digital</span>
    </div>
    <div class="product-actions">
      {paymentUrl && <a class="product-pay-link" href={paymentUrl} target="_blank" rel="noreferrer">{paymentLabel}</a>}
      <a href={id ? `/produk/${id}` : whatsappUrl}>Detail</a>
    </div>
  </div>
</article>
