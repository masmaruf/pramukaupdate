---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";
import { ClientRouter } from "astro:transitions";
import { whatsappUrl } from "../lib/contact";
import { organizationSchema, websiteSchema } from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  canonicalUrl?: string;
  noindex?: boolean;
  pagefind?: boolean;
  analytics?: {
    contentType?: "website" | "article" | "product" | "page";
    contentId?: string;
    contentTitle?: string;
    category?: string;
    author?: string;
    publishedAt?: string;
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Pramuka Update — media digital Pramuka untuk gagasan, administrasi, produk, dan kelas.",
  image = "/og-default.svg",
  type = "website",
  canonicalUrl,
  noindex = false,
  pagefind = true,
  analytics,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? Astro.url;
const canonical = canonicalUrl ? new URL(canonicalUrl, site).toString() : new URL(Astro.url.pathname, site).toString();
const socialImage = new URL(image, Astro.site ?? Astro.url).toString();
const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const structuredData = [organizationSchema(site), websiteSchema(site), ...pageSchemas];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {structuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main {...(pagefind ? { "data-pagefind-body": true } : {})}>
      <slot />
    </main>
    <Footer />
    <a class="fab" href={whatsappUrl()} aria-label="Hubungi PramukaUpdate lewat WhatsApp">WA</a>
    <Analytics {...analytics} contentType={analytics?.contentType ?? type} contentTitle={analytics?.contentTitle ?? title} />
  </body>
</html>

