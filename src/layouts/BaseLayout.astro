---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";
import { ClientRouter } from "astro:transitions";
import { whatsappUrl } from "../lib/contact";
import { organizationSchema, websiteSchema } from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageType?: string;
  type?: "website" | "article";
  canonicalUrl?: string;
  noindex?: boolean;
  pagefind?: boolean;
  analytics?: {
    contentType?: "website" | "article" | "product" | "page";
    contentId?: string;
    contentTitle?: string;
    category?: string;
    author?: string;
    publishedAt?: string;
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Pramuka Update — media digital Pramuka untuk gagasan, administrasi, produk, dan kelas.",
  image = "/og-default.png",
  imageType,
  type = "website",
  canonicalUrl,
  noindex = false,
  pagefind = true,
  analytics,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? Astro.url;
const canonical = canonicalUrl ? new URL(canonicalUrl, site).toString() : new URL(Astro.url.pathname, site).toString();
const socialImage = image.startsWith('http') ? image : new URL(image, Astro.site ?? Astro.url).toString();
const detectedImageType = imageType ?? (image.endsWith('.jpg') || image.endsWith('.jpeg') ? 'image/jpeg' : image.endsWith('.webp') ? 'image/webp' : 'image/png');
const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const structuredData = [organizationSchema(site), websiteSchema(site), ...pageSchemas];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta property="og:site_name" content="PramukaUpdate" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={detectedImageType} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@pramukaupdate" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={title} />
    {structuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>
  </head>
  <body>
    <div id="reading-progress"></div>
    <script is:inline>
      let scrollListener = null;
      document.addEventListener('astro:page-load', () => {
        const progressBar = document.getElementById('reading-progress');
        if (!progressBar) return;
        if (scrollListener) window.removeEventListener('scroll', scrollListener);
        scrollListener = () => {
          const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          if (scrollHeight <= 0) return;
          const scrollPercentage = (scrollTop / scrollHeight) * 100;
          progressBar.style.width = scrollPercentage + '%';
        };
        window.addEventListener('scroll', scrollListener, { passive: true });
        scrollListener();
      });
    </script>
    <Header />
    <main {...(pagefind ? { "data-pagefind-body": true } : {})}>
      <slot />
    </main>
    <Footer />
    <a class="fab fab-whatsapp" href={whatsappUrl()} aria-label="Hubungi PramukaUpdate lewat WhatsApp" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="20" height="20" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M380.9 97.1C339 55.1 283.6 32 224.1 32 100.3 32 0 132.3 0 256c0 45 11.8 88.9 34.3 127.9L0 480l99.1-32.8C140.5 458 181.4 464 224.1 464 347.9 464 448 363.7 448 240c0-59.5-23.1-114.9-67.1-154.9zM224.1 400c-39.1 0-77.1-10.5-110.3-30.4l-7.9-4.6-58.9 19.5 19.8-57.4-5-8c-21.1-33.7-32.2-73.3-32.2-114.7 0-121.4 98.7-220.1 220.1-220.1 59.6 0 115 23.1 154.9 67.1 40 41.9 62.1 98.7 62.1 156.7 0 121.4-98.7 220.1-220.9 220.1zm101-138.5c-5.6-2.8-33.1-16.3-38.1-18.1-5-1.8-8.6-2.8-12.2 2.8-3.6 5.6-13.9 18.1-17 21.8-3.1 3.6-6.2 4.1-11.8 1.4-32.1-16-53.1-28.7-74.1-65.6-5.6-9.6 5.6-8.9 16.2-29.6 1.8-3.6.9-6.8-.5-9.6-1.4-2.8-12.2-29.4-16.7-40.1-4.4-10.5-8.9-9.6-12.2-9.8-3.1-.2-6.7-.2-10.2-.2-3.6 0-9.4 1.4-14.3 6.8-4.9 5.6-18.6 18.2-18.6 44.5 0 26.3 19 51.7 21.6 55.3 2.8 3.6 37.2 56.7 90 77.2 52.8 20.5 52.8 13.7 62.3 12.9 9.6-.8 31.2-12.7 35.6-25 4.4-12.2 4.4-22.7 3.1-25-.9-2.4-5-3.6-10.6-6.2z"/>
      </svg>
    </a>
    <Analytics {...analytics} contentType={analytics?.contentType ?? type} contentTitle={analytics?.contentTitle ?? title} />
  </body>
</html>

