---
const target = "/keystatic";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <title>Menuju Keystatic CMS | PramukaUpdate</title>
  </head>
  <body>
    <p>CMS PramukaUpdate sekarang pindah ke <a href={target}>Keystatic</a>.</p>
    <script is:inline>
      window.location.replace("/keystatic");
    </script>
  </body>
</html>
