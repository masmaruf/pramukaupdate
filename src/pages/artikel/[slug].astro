---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("artikel");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<BaseLayout
  title={`${article.data.title} | Pramuka Update`}
  description={article.data.excerpt}
  image={article.data.image}
  type="article"
>
  <article class="article-detail shell">
    <Breadcrumb
      items={[
        { label: "Beranda", href: "/" },
        { label: "Artikel", href: "/artikel" },
        { label: article.data.title },
      ]}
    />
    <header>
      <span class="eyebrow">{article.data.category}</span>
      <h1>{article.data.title}</h1>
      <p>{article.data.excerpt}</p>
      <div class="article-meta">
        <span>
          {article.data.publishedAt.toLocaleDateString("id-ID", {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </span>
        <span>{article.data.readTime}</span>
      </div>
    </header>
    <img src={article.data.image} alt="" />
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
